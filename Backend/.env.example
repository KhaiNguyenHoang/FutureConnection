# Copy this to .env (gitignored) and fill in real values.
# .NET reads these as environment variables; double-underscore (__) is the section separator.
#
# Required for all services that connect to SQL Server:
ConnectionStrings__DefaultConnection=Server=localhost,1433;Database=FutureConnectionDb;User Id=sa;Password=CHANGE_ME;TrustServerCertificate=True

# Required for all services that validate JWTs:
# Must be at least 32 characters and kept secret.
Jwt__Key=CHANGE_ME_USE_A_LONG_RANDOM_SECRET_HERE

# Optional overrides (defaults are already set in appsettings.json):
# Jwt__Issuer=FutureConnection.IdentityService
# Jwt__Audience=FutureConnection.Clients

# Cloudinary (used by services that upload media):
# Cloudinary__CloudName=your_cloud_name
# Cloudinary__ApiKey=your_api_key
# Cloudinary__ApiSecret=your_api_secret
